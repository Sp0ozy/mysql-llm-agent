<tr>
  <td><input type="text" name="title" value="{{ item.title }}"
       hx-patch="/plan/row/{{ index }}" hx-include="closest tr"
       hx-target="closest tr" hx-swap="outerHTML" hx-trigger="blur"></td>
  <td><input type="text" name="question" value="{{ item.question }}"
       hx-patch="/plan/row/{{ index }}" hx-include="closest tr"
       hx-target="closest tr" hx-swap="outerHTML" hx-trigger="blur"></td>
  <td>
    <select name="viz_type"
            hx-patch="/plan/row/{{ index }}" hx-include="closest tr"
            hx-target="closest tr" hx-swap="outerHTML" hx-trigger="change">
      {% for v in viz_options %}
        <option value="{{ v }}"{% if v == item.viz_type %} selected{% endif %}>{{ v }}</option>
      {% endfor %}
    </select>
  </td>
  <td><input type="text" name="x_label" value="{{ item.x_label }}"
       hx-patch="/plan/row/{{ index }}" hx-include="closest tr"
       hx-target="closest tr" hx-swap="outerHTML" hx-trigger="blur"></td>
  <td><input type="text" name="y_label" value="{{ item.y_label }}"
       hx-patch="/plan/row/{{ index }}" hx-include="closest tr"
       hx-target="closest tr" hx-swap="outerHTML" hx-trigger="blur"></td>
  <td>
    <button class="btn-danger"
            hx-delete="/plan/row/{{ index }}"
            hx-target="#plan-area"
            hx-swap="innerHTML">×</button>
  </td>
</tr>
