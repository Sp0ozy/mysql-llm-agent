<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}MySQL LLM Agent{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      color: #222; background: #fafafa; margin: 0; padding: 2rem;
    }
    main { max-width: 960px; margin: 0 auto; }
    h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
    h2 { font-size: 1.2rem; margin: 0 0 0.75rem 0; }
    .meta { color: #777; font-size: 0.9rem; margin-bottom: 2rem; }
    section.card {
      background: #fff; border: 1px solid #e3e3e3; border-radius: 6px;
      padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
    }

    /* Buttons */
    button {
      cursor: pointer; border: none; border-radius: 4px;
      padding: 0.4rem 1rem; font-size: 0.875rem; font-family: inherit;
    }
    .btn-primary  { background: #2563eb; color: #fff; }
    .btn-primary:hover  { background: #1d4ed8; }
    .btn-secondary { background: #e5e7eb; color: #333; }
    .btn-secondary:hover { background: #d1d5db; }
    .btn-run      { background: #16a34a; color: #fff; }
    .btn-run:hover { background: #15803d; }
    .btn-danger   { background: transparent; color: #dc2626; border: 1px solid #dc2626; padding: 0.2rem 0.5rem; }
    .btn-danger:hover { background: #dc2626; color: #fff; }

    /* Forms */
    label { font-size: 0.9rem; }
    input[type=number] { width: 5rem; padding: 0.3rem 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875rem; }

    /* Plan table */
    table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-top: 0.75rem; }
    th { text-align: left; padding: 0.4rem 0.5rem; background: #f9fafb; border-bottom: 2px solid #e5e7eb; color: #555; font-weight: 600; }
    td { padding: 0.35rem 0.4rem; border-bottom: 1px solid #f0f0f0; }
    td input[type=text], td select {
      width: 100%; padding: 0.3rem 0.4rem;
      border: 1px solid #e0e0e0; border-radius: 3px; font-size: 0.83rem; font-family: inherit;
    }
    td input[type=text]:focus, td select:focus { outline: none; border-color: #2563eb; }

    /* Results */
    section.result { background: #fff; border: 1px solid #e3e3e3; border-radius: 6px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; }
    section.result img { display: block; max-width: 100%; height: auto; margin: 0.75rem auto 1rem; }
    p.insight { background: #f0f9ff; border-left: 3px solid #0ea5e9; padding: 0.65rem 1rem; margin: 0 0 0.75rem; font-style: italic; color: #0c4a6e; line-height: 1.5; }
    details { font-size: 0.85rem; color: #555; margin-top: 0.35rem; }
    details summary { cursor: pointer; user-select: none; }
    pre { background: #f3f3f3; padding: 0.75rem; border-radius: 4px; overflow-x: auto; font-size: 0.8rem; margin-top: 0.4rem; }
    p.error { color: #a00; font-style: italic; }

    /* Status */
    .status-running { color: #d97706; }
    .status-done    { color: #16a34a; font-weight: 600; }
    .status-failed  { color: #dc2626; font-weight: 600; }

    /* HTMX loading indicator */
    .htmx-indicator { display: none; color: #666; font-size: 0.85rem; }
    .htmx-request .htmx-indicator { display: inline; }
  </style>
</head>
<body>
<main>
  {% block content %}{% endblock %}
</main>
</body>
</html>
