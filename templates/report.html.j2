<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ report_title }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; color: #222; background: #fafafa; margin: 0; padding: 2rem; }
  main { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
  .meta { color: #777; font-size: 0.9rem; margin-bottom: 2rem; }
  section { background: #fff; border: 1px solid #e3e3e3; border-radius: 6px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; }
  h2 { font-size: 1.2rem; margin: 0 0 0.75rem 0; }
  img { display: block; max-width: 100%; height: auto; margin: 0 auto 1rem auto; }
  p.insight { font-size: 1rem; line-height: 1.5; margin: 0 0 1rem 0; }
  details { font-size: 0.85rem; color: #555; }
  details summary { cursor: pointer; user-select: none; }
  pre { background: #f3f3f3; padding: 0.75rem; border-radius: 4px; overflow-x: auto; font-size: 0.8rem; }
  .error { color: #a00; font-style: italic; }
</style>
</head>
<body>
<main>
  <h1>{{ report_title }}</h1>
  <p class="meta">{{ item_count }} visualization{{ '' if item_count == 1 else 's' }}</p>

  {% for item in items %}
  <section>
    <h2>{{ item.title }}</h2>
    {% if item.error %}
      <p class="error">Failed to generate this item: {{ item.error }}</p>
      {% if item.sql %}
      <details><summary>Attempted SQL</summary><pre>{{ item.sql }}</pre></details>
      {% endif %}
    {% else %}
      <img src="data:image/png;base64,{{ item.png_b64 }}" alt="{{ item.title }}">
      <p class="insight">{{ item.insight }}</p>
      <details><summary>SQL</summary><pre>{{ item.sql }}</pre></details>
    {% endif %}
  </section>
  {% endfor %}
</main>
</body>
</html>
